{
  "name": "astro-nanostores-i18n",
  "version": "1.0.0",
  "description": "An integration of @nanostores/i18n into Astro.",
  "keywords": [
    "astro",
    "astro-component",
    "i18n",
    "tooling",
    "utils",
    "utility",
    "withastro"
  ],
  "homepage": "https://github.com/openscript/astro-i18n/tree/main/libs/astro-nanostores-i18n",
  "license": "MIT",
  "author": "Robin Bühler",
  "repository": "github:openscript/astro-i18n",
  "type": "module",
  "main": "./dist/integration.js",
  "types": "./dist/integration.d.ts",
  "exports": {
    ".": {
      "import": "./dist/integration.js",
      "types": "./dist/integration.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime.js",
      "types": "./dist/runtime.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware.js",
      "types": "./dist/middleware.d.ts"
    }
  },
  "bin": {
    "extract-messages": "./dist/bin/extract.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@nanostores/i18n": "^1.2.0",
    "astro": "^5.5.0 || ^6.0.0 || ^7.0.0",
    "nanostores": "^1.0.1"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "^2.0.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.4",
    "astro": "^7.0.2",
    "astro-utils-i18n": "workspace:*",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "tslib": "^2.8.1",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@astrojs/compiler": "^4.0.0",
    "fast-glob": "^3.3.3",
    "nanostores": "^1.3.0",
    "typescript": "^6.0.3"
  }
}